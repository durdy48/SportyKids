# =============================================================================
# SportyKids API — Environment Variables
# =============================================================================
# Copy this file to .env and update values as needed:
#   cp .env.example .env
# =============================================================================

# =============================================================================
# Database
# =============================================================================

# SQLite (default for local development):
DATABASE_URL="file:./dev.db"

# PostgreSQL (production / docker compose):
# DATABASE_URL="postgresql://sportykids:sportykids@localhost:5432/sportykids"

# =============================================================================
# Cache Provider
# =============================================================================

# "memory" (default) — In-memory cache, single-process only
# "redis"            — Redis-backed cache, multi-instance ready
CACHE_PROVIDER=memory

# Redis connection URL (only used when CACHE_PROVIDER=redis)
# Start Redis: docker compose up -d redis
REDIS_URL=redis://localhost:6379

# =============================================================================
# Authentication (JWT)
# =============================================================================

# Secret keys for JWT token signing (REQUIRED in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# =============================================================================
# AI Provider Configuration
# =============================================================================

# Primary provider: "groq" (default — free tier, cloud), "cerebras", "gemini", "openrouter", "anthropic" (paid)
# Fallback chain: AI_FALLBACK_PROVIDERS=cerebras,gemini (comma-separated, tried in order if primary fails)
#
# Free tier comparison:
#   groq     — 14,400 req/day, 6,000 tokens/min  — console.groq.com       (recommended primary)
#   cerebras — 30 req/min, generous daily limit   — cloud.cerebras.ai      (recommended fallback)
#   gemini   — 1,500 req/day, 15 req/min          — aistudio.google.com    (secondary fallback)
#   openrouter — varies by model                  — openrouter.ai          (many free models, less reliable)
AI_PROVIDER=groq
# AI_FALLBACK_PROVIDERS=cerebras

# --- Groq (default — free tier, no credit card needed) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Cerebras (free tier, OpenAI-compatible, very fast) ---
# Sign up at https://cloud.cerebras.ai for a free API key
# CEREBRAS_API_KEY=
# CEREBRAS_MODEL=llama3.1-8b
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# --- Google Gemini (free tier via AI Studio) ---
# Sign up at https://aistudio.google.com for a free API key
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# --- OpenRouter (cloud alternative — many free models) ---
# Sign up at https://openrouter.ai for a free API key
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL_MODERATION=meta-llama/llama-3.2-3b-instruct:free
# OPENROUTER_MODEL_GENERATION=google/gemma-2-9b-it:free

# --- Anthropic (production — paid) ---
# ANTHROPIC_API_KEY=
# AI_MODEL_MODERATION=claude-haiku-4-5-20251001
# AI_MODEL_GENERATION=claude-sonnet-4-6

# --- Ollama (local, offline) ---
# Only use if you have Ollama installed and running locally.
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL_MODERATION=llama3.2:3b
# OLLAMA_MODEL_GENERATION=gemma2:9b

# --- Shared AI config ---
AI_MAX_RETRIES=3
AI_RETRY_DELAY_MS=1000
AI_RATE_LIMIT_RPM=30

# =============================================================================
# Rate Limiting (requests per minute per IP)
# =============================================================================

RATE_LIMIT_AUTH=5
RATE_LIMIT_PIN=10
RATE_LIMIT_CONTENT=60
RATE_LIMIT_SYNC=2
RATE_LIMIT_DEFAULT=100

# =============================================================================
# Email (Weekly Digest)
# =============================================================================

# SMTP settings for sending weekly digest emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sportykids.app

# =============================================================================
# OAuth (Planned — not yet implemented)
# =============================================================================

# Google OAuth 2.0
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Apple Sign In
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# =============================================================================
# Monitoring & Analytics (opt-in)
# =============================================================================

# Sentry error tracking — leave empty to disable
SENTRY_DSN=

# PostHog analytics — leave empty to disable
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# =============================================================================
# Push Notifications
# =============================================================================

# Expo push notification service (used automatically via expo-server-sdk)
# No configuration needed — tokens are registered per-device

# =============================================================================
# Server
# =============================================================================

PORT=3001
NODE_ENV=development
