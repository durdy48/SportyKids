{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmitOnError": false
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.integration.test.ts"],
  "references": [{ "path": "../../packages/shared" }]
}
