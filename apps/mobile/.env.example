# SportyKids Mobile — Environment Variables
# Copy to .env and adjust values.

# Override API base URL (optional — auto-detected from EAS channel)
# EXPO_PUBLIC_API_BASE=https://sportykids-api.fly.dev/api

# Sentry crash reporting DSN (optional — disabled if empty)
# Only collects technical crash data, all PII is stripped via beforeSend.
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
